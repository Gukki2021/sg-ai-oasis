# ─── Supabase (required for live DB mode) ──────────────────────
# Get these from: https://app.supabase.com/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI...

# ─── App URL (used for internal API calls in SSR) ───────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# On Vercel, set this to your deployment URL:
# NEXT_PUBLIC_BASE_URL=https://sg-ai-oasis.vercel.app

# ─── Scraper webhook secret (optional) ─────────────────────────
# Must match the x-cron-secret header sent by GitHub Actions
CRON_SECRET=your-random-secret-here
